# Art Bank Core - Environment Variables Template
# Copy this file to .dev.vars for local development
# For production, use: wrangler secret put <KEY_NAME>

# ============================================
# JWT Configuration (CRITICAL - CHANGE IN PRODUCTION!)
# ============================================
JWT_SECRET=art-bank-secret-key-change-in-production-v1-2024
# IMPORTANT: Generate a strong random secret for production:
# Use: openssl rand -base64 32

# ============================================
# Database Configuration (Cloudflare D1)
# ============================================
# Local development uses D1 local mode automatically
# Production database is configured in wrangler.jsonc

# ============================================
# Analytics Service Configuration
# ============================================
ANALYTICS_SERVICE_URL=http://localhost:5000
# Production: Use your deployed Analytics Service URL

# ============================================
# Cloudflare Pages Configuration
# ============================================
# These are automatically set by Cloudflare Pages:
# CF_PAGES=1
# CF_PAGES_BRANCH=main
# CF_PAGES_COMMIT_SHA=<git-sha>
# CF_PAGES_URL=https://<project>.pages.dev

# ============================================
# Optional: External Services (if using)
# ============================================
# OPENAI_API_KEY=sk-...
# STRIPE_SECRET_KEY=sk_test_...
# SENDGRID_API_KEY=SG...
# S3_ACCESS_KEY_ID=AKIA...
# S3_SECRET_ACCESS_KEY=...

# ============================================
# Development Settings
# ============================================
NODE_ENV=development
# Production: NODE_ENV=production

# ============================================
# Notes:
# ============================================
# 1. Never commit .dev.vars or .env to git
# 2. For local development: Copy this file to .dev.vars
# 3. For production secrets: Use wrangler secret put <KEY_NAME>
# 4. Cloudflare Workers doesn't support .env files
# 5. All environment variables must be configured in wrangler.jsonc or via secrets
