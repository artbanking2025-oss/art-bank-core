{
  "name": "art-bank",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=art-bank-db --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy dist --project-name art-bank",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name art-bank --branch main",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:create": "wrangler d1 create art-bank-db",
    "db:list": "wrangler d1 list",
    "db:info": "wrangler d1 info art-bank-db",
    "db:migrate:local": "wrangler d1 migrations apply art-bank-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply art-bank-db",
    "db:seed:local": "wrangler d1 execute art-bank-db --local --file=./seed.sql",
    "db:seed:prod": "wrangler d1 execute art-bank-db --file=./seed.sql",
    "db:console:local": "wrangler d1 execute art-bank-db --local",
    "db:console:prod": "wrangler d1 execute art-bank-db",
    "db:backup": "wrangler d1 execute art-bank-db --command='SELECT * FROM users' --json > backup_users.json",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed:local",
    "secret:put": "wrangler secret put",
    "secret:list": "wrangler secret list --project-name art-bank",
    "logs:tail": "wrangler pages deployment tail --project-name art-bank",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "whoami": "wrangler whoami",
    "pages:create": "wrangler pages project create art-bank --production-branch main",
    "pages:list": "wrangler pages project list",
    "pages:delete": "wrangler pages project delete art-bank",
    "test:prod": "curl https://art-bank.pages.dev/api/health/circuit-breakers"
  },
  "dependencies": {
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}